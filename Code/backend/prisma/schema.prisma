generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id_user    Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(100)
  name       String   @db.VarChar(40)
  password   String   @db.VarChar(100)
  created_at DateTime @default(now())
  is_active  Boolean  @default(true) // Indica se o usuário está ativo ou não, útil para desativar contas sem deletar

  // Relations
  Storages      Storage[]            @relation("UserStorage")
  permissions Storage_Permission[]
  Product     Product[]
}

model Storage {
  id_Storage   Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  created_at DateTime @default(now())

  // Relations
  users         User[]             @relation("UserStorage")
  permissions   Storage_Permission[]
  Storage_Product Storage_Product[]
}

model Storage_Product {
  id         Int @id @default(autoincrement())
  id_Storage   Int
  id_product Int

  Storage   Storage   @relation(fields: [id_Storage], references: [id_Storage])
  product Product @relation(fields: [id_product], references: [id_product])

  @@unique([id_Storage, id_product]) 
}

model Product {
  id_product  Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(200)
  expiration  DateTime @db.DateTime()
  category    String   @db.VarChar(100)
  id_user     Int

  // Relations
  creator       User            @relation(fields: [id_user], references: [id_user])
  Storage_belongs Storage_Product[]
}

model Storage_Permission {
  id           Int          @id @default(autoincrement())
  id_user      Int
  id_Storage     Int
  Access_Level Access_Level

  // Relations
  user  User  @relation(fields: [id_user], references: [id_user])
  Storage Storage @relation(fields: [id_Storage], references: [id_Storage])

  @@unique([id_user, id_Storage]) // para assegurar que um usuário só pode ter uma permissão por estoque
}

enum Access_Level {
  Owner
  CoOwner
  Guest
}
