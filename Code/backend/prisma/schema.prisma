generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id_user    Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(100)
  name       String   @db.VarChar(40)
  password   String   @db.VarChar(100)
  created_at DateTime @default(now())
  is_active  Boolean  @default(true)

  // Relations
  permissions    Storage_Permission[]
  recipes        Recipe[]
  history        History[]
  passwordResets PasswordReset[] // <-- relação inversa adicionada
  is2FAEnabled     Boolean  @default(false)
  twoFactorSecret  String?  // opcional
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime

  // Relations
  user User @relation(fields: [userId], references: [id_user])
}

model Storage {
  id_Storage Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  location   String   @db.VarChar(100)
  created_at DateTime @default(now())

  // Relations
  permissions  Storage_Permission[]
  Storage_Item Storage_Item[]
}

model Storage_Item {
  id         Int @id @default(autoincrement())
  id_Storage Int
  id_Item    Int

  Storage Storage @relation(fields: [id_Storage], references: [id_Storage])
  Item    Item    @relation(fields: [id_Item], references: [id_Item])

  @@unique([id_Storage, id_Item])
}

model Item {
  id_Item     Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(200)
  expiration  DateTime @db.DateTime()
  category    category
  quantity    Int?
  created_at  DateTime @default(now())

  // Relations
  Storage_belongs Storage_Item[]
  Recipe_belongs    Recipe_Item[]
  history         History[]
}

model Storage_Permission {
  id           Int          @id @default(autoincrement())
  id_user      Int
  id_Storage   Int
  Access_Level Access_Level

  // Relations
  user    User    @relation(fields: [id_user], references: [id_user])
  Storage Storage @relation(fields: [id_Storage], references: [id_Storage])

  @@unique([id_user, id_Storage]) // para assegurar que um usuário só pode ter uma permissão por estoque
}

model Recipe {
  id_Recipe   Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(200)
  created_at  DateTime @default(now())
  id_user     Int

  // Relations
  user        User        @relation(fields: [id_user], references: [id_user])
  ingredients Recipe_Item[]
}

model Recipe_Item {
  id       Int @id @default(autoincrement())
  id_Recipe  Int
  id_Item  Int
  quantity Int

  Recipe Recipe @relation(fields: [id_Recipe], references: [id_Recipe])
  Item Item @relation(fields: [id_Item], references: [id_Item])

  @@unique([id_Recipe, id_Item])
}

model History {
  id_History Int      @id @default(autoincrement())
  id_user    Int
  id_item    Int?
  action     String   @db.VarChar(50)
  quantity   Int?
  created_at DateTime @default(now())

  // Relations
  user User  @relation(fields: [id_user], references: [id_user])
  item Item? @relation(fields: [id_item], references: [id_Item])
}

enum Access_Level {
  Owner
  CoOwner
  Guest
}

enum category {
  Vegetables
  Fruits
  Meats
  FishAndSeafood
  Dairy
  GrainsAndCereals
  NutsAndSeeds
  BakedGoods
  Condiments
  SpicesAndHerbs
  Beverages
  FrozenFoods
  CannedFoods
  OilsAndFats
  Snacks
  SweetsAndDesserts
  OthersFood
 //português
  Legumes
  Frutas
  Carnes
  PeixesEFrutosDoMar
  Laticinios
  CereaisEGraos
  NozesESementes
  ProdutosAssados
  Condimentos
  EspeciariasEErvas
  Bebidas
  AlimentosCongelados
  AlimentosEnlatados
  OleosEGorduras
  Petiscos
  DocesESobremesas
  OutrosAlimentos
}
