generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id_user    Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(100)
  name       String   @db.VarChar(40)
  password   String   @db.VarChar(100)
  created_at DateTime @default(now())
  is_active  Boolean  @default(true) // Indica se o usuário está ativo ou não, útil para desativar contas sem deletar

  // Relations
  permissions Storage_Permission[]
  dishes      Dish[]
  history     History[]
}

model Storage {
  id_Storage   Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  location   String   @db.VarChar(100)
  created_at DateTime @default(now())

  // Relations
  permissions   Storage_Permission[]
  Storage_Item Storage_Item[]
}

model Storage_Item {
  id         Int @id @default(autoincrement())
  id_Storage   Int
  id_Item Int

  Storage   Storage   @relation(fields: [id_Storage], references: [id_Storage])
  Item Item @relation(fields: [id_Item], references: [id_Item])

  @@unique([id_Storage, id_Item]) 
}

model Item {
  id_Item  Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(200)
  expiration  DateTime @db.DateTime()
  category    String   @db.VarChar(100)
  quantity    Int?
  created_at  DateTime @default(now())

  // Relations
  Storage_belongs Storage_Item[]
  Dish_belongs    Dish_Item[]
  history         History[]
}

model Storage_Permission {
  id           Int          @id @default(autoincrement())
  id_user      Int
  id_Storage     Int
  Access_Level Access_Level

  // Relations
  user  User  @relation(fields: [id_user], references: [id_user])
  Storage Storage @relation(fields: [id_Storage], references: [id_Storage])

  @@unique([id_user, id_Storage]) // para assegurar que um usuário só pode ter uma permissão por estoque
}

model Dish {
  id_Dish     Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(200)
  created_at  DateTime  @default(now())
  id_user     Int

  // Relations
  user        User      @relation(fields: [id_user], references: [id_user])
  ingredients Dish_Item[]
}

model Dish_Item {
  id         Int    @id @default(autoincrement())
  id_Dish    Int
  id_Item    Int
  quantity   Int

  Dish       Dish  @relation(fields: [id_Dish], references: [id_Dish])
  Item       Item  @relation(fields: [id_Item], references: [id_Item])

  @@unique([id_Dish, id_Item])
}

model History {
  id_History   Int      @id @default(autoincrement())
  id_user      Int
  id_item      Int?
  action       String   @db.VarChar(50)
  quantity     Int?
  created_at   DateTime @default(now())

  // Relations
  user User @relation(fields: [id_user], references: [id_user])
  item Item? @relation(fields: [id_item], references: [id_Item])
}


enum Access_Level {
  Owner
  CoOwner
  Guest
}