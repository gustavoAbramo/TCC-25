generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id_user    Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(100)
  name       String   @db.VarChar(40)
  password   String   @db.VarChar(100)
  created_at DateTime @default(now())
  is_active  Boolean  @default(true) // Indica se o usuário está ativo ou não, útil para desativar contas sem deletar

  // Relations
  stocks      Stock[]            @relation("UserStock")
  permissions Stock_Permission[]
  Product     Product[]
}

model Stock {
  id_stock   Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  created_at DateTime @default(now())

  // Relations
  users         User[]             @relation("UserStock")
  permissions   Stock_Permission[]
  Stock_Product Stock_Product[]
}

model Stock_Product {
  id         Int @id @default(autoincrement())
  id_stock   Int
  id_product Int

  stock   Stock   @relation(fields: [id_stock], references: [id_stock])
  product Product @relation(fields: [id_product], references: [id_product])

  @@unique([id_stock, id_product]) 
}

model Product {
  id_product  Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(200)
  expiration  DateTime @db.DateTime()
  category    String   @db.VarChar(100)
  id_user     Int

  // Relations
  creator       User            @relation(fields: [id_user], references: [id_user])
  stock_belongs Stock_Product[]
}

model Stock_Permission {
  id           Int          @id @default(autoincrement())
  id_user      Int
  id_stock     Int
  Access_Level Access_Level

  // Relations
  user  User  @relation(fields: [id_user], references: [id_user])
  stock Stock @relation(fields: [id_stock], references: [id_stock])

  @@unique([id_user, id_stock]) // para assegurar que um usuário só pode ter uma permissão por estoque
}

enum Access_Level {
  Owner
  CoOwner
  Guest
}
