<!doctype html>
<html lang="en">
    <head>
        <title>Bem-vindo!</title>
        <!-- Required meta tags -->
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
        <!-- Bootstrap CSS -->
        <link href="css/bootstrap.min.css" rel="stylesheet" />
    </head>
    
    <body>
        <!-- Header com a navbar -->
        <header>
            <%- include('../partials/nav') %> <!-- Inclui o menu de navegação -->
        </header>

        <main class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white text-center">
                            <h2>Bem-vindo, <%= user.nome %>!</h2> <!-- Exibe o nome do usuário logado -->
                        </div>
                        <div class="card-body">
                            <p>Você está autenticado e pode acessar suas funcionalidades!</p>
                            <!-- Aqui podem vir mais informações ou links -->
                            <div class="mb-3">
                                <a href="/perfil" class="btn btn-info">Ir para meu perfil</a>
                            </div>
                            <div class="mb-3">
                                <a href="/sair" class="btn btn-danger">Sair</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <footer>
            <%- include('../partials/footer') %> <!-- Inclui o rodapé -->
        </footer>
        
        <!-- Bootstrap JS -->
        <script src="js/bootstrap.bundle.min.js"></script>
    </body>
</html>

